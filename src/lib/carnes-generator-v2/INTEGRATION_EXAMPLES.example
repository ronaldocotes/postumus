/**
 * Exemplo de integração da API de carnês no frontend
 * Use este código como referência para integrar geração de PDFs
 */

// ──────────────────────────────────────────────────────────────────────
// 1️⃣  COMPONENTE REACT PARA GERAR CARNÊ
// ──────────────────────────────────────────────────────────────────────

import { useState } from 'react';

export function GerarCarneButton({ carne, cliente }: { carne: any; cliente: any }) {
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const handleGerarCarne = async () => {
    setLoading(true);
    setError(null);

    try {
      // Prepara os dados
      const payload = {
        cliente: cliente.name,
        cpf: cliente.cpf,
        nParcelas: carne.installments?.length || 12,
        total: carne.totalValue || 'R$ 0,00',
        valorParcela: carne.installmentValue || 'R$ 0,00',
        carneId: carne.id,
        paleta: 'azul', // ou obter das preferências
      };

      // Chama a API
      const response = await fetch('/api/carnes/gerar-pdf', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error(`Erro: ${response.statusText}`);
      }

      // Obtém o PDF como blob
      const blob = await response.blob();

      // Cria URL para download
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `carne_${carne.id}.pdf`;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      document.body.removeChild(a);

      alert('✅ Carnê gerado com sucesso!');
    } catch (err: any) {
      setError(err.message);
      alert(`❌ Erro: ${err.message}`);
    } finally {
      setLoading(false);
    }
  };

  return (
    <button
      onClick={handleGerarCarne}
      disabled={loading}
      className="btn btn-primary"
    >
      {loading ? '⏳ Gerando PDF...' : '📄 Gerar Carnê PDF'}
    </button>
  );
}

// ──────────────────────────────────────────────────────────────────────
// 2️⃣  FETCH SIMPLES (VANILLA JS)
// ──────────────────────────────────────────────────────────────────────

async function downloadCarne(carneData) {
  try {
    const response = await fetch('/api/carnes/gerar-pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(carneData),
    });

    if (!response.ok) throw new Error('Erro na geração');

    const blob = await response.blob();
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `carne_${carneData.carneId}.pdf`;
    link.click();
    URL.revokeObjectURL(url);
  } catch (error) {
    console.error('Erro ao gerar carnê:', error);
  }
}

