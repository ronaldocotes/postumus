generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  GERENTE
  SECRETARIA
  COBRADOR
  AGENTE_FUNERARIO
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  BANK_TRANSFER
  OTHER
}

enum ClientStatus {
  ACTIVE
  CANCELLED
  SUSPENDED
}

enum PaymentLocation {
  LOJA
  RESIDENCIA
}

enum Parentesco {
  CONJUGE
  FILHO
  FILHA
  PAI
  MAE
  IRMAO
  IRMA
  NETO
  NETA
  OUTRO
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SECRETARIA)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments         Payment[]
  assignedClients  Client[]  @relation("CobradorCliente")
}

model Client {
  id              String       @id @default(cuid())
  code            String?      @unique
  name            String
  cpf             String?      @unique
  rg              String?
  birthDate       DateTime?
  phone           String?
  cellphone       String?
  email           String?
  address         String?
  number          String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  zipCode         String?
  civilStatus     String?
  profession      String?
  workplace       String?
  fatherName      String?
  motherName      String?
  spouseName      String?
  dueDay          Int?         @default(10)
  paymentLocation PaymentLocation? @default(RESIDENCIA)
  contractDate    DateTime?
  cancelDate      DateTime?
  cancelReason    String?
  status          ClientStatus @default(ACTIVE)
  monthlyValue    Float?
  latitude        Float?
  longitude       Float?
  billingAddressSame Boolean  @default(true)
  billingAddress     String?
  billingNumber      String?
  billingComplement  String?
  billingNeighborhood String?
  billingCity        String?
  billingState       String?
  billingZipCode     String?
  billingReference   String?
  billingLatitude    Float?
  billingLongitude   Float?
  notes           String?
  notes2          String?
  cobradorId      String?
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  cobrador     User?        @relation("CobradorCliente", fields: [cobradorId], references: [id])
  dependents   Dependent[]
  carnes       Carne[]
  transactions FinancialTransaction[]
  serviceSales ServiceSale[]
}

model Dependent {
  id           String     @id @default(cuid())
  clientId     String
  name         String
  birthDate    DateTime?
  relationship Parentesco @default(OUTRO)
  cpf          String?
  phone        String?
  notes        String?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client Client @relation(fields: [clientId], references: [id])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  cnpj        String?  @unique
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  contactName String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products     Product[]
  transactions FinancialTransaction[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?  @unique
  price       Float
  cost        Float?
  stock       Int      @default(0)
  minStock    Int      @default(0)
  supplierId  String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplier Supplier? @relation(fields: [supplierId], references: [id])
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  cost        Float?
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales ServiceSale[]
}

model ServiceSale {
  id            String         @id @default(cuid())
  serviceId     String
  clientId      String?
  clientName    String?
  quantity      Int            @default(1)
  unitPrice     Float
  totalPrice    Float
  discount      Float?
  date          DateTime       @default(now())
  paymentMethod PaymentMethod?
  status        PaymentStatus  @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  service Service @relation(fields: [serviceId], references: [id])
  client  Client? @relation(fields: [clientId], references: [id])
}

model Carne {
  id           String   @id @default(cuid())
  clientId     String
  year         Int
  totalValue   Float
  installments Int      @default(12)
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id])
  payments Payment[]
}

model Payment {
  id              String          @id @default(cuid())
  carneId         String
  installment     Int
  dueDate         DateTime
  amount          Float
  paidAmount      Float?
  paidAt          DateTime?
  status          PaymentStatus   @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentLocation PaymentLocation?
  pixCode         String?
  receivedById    String?
  latitude        Float?
  longitude       Float?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  carne      Carne  @relation(fields: [carneId], references: [id])
  receivedBy User?  @relation(fields: [receivedById], references: [id])
}

model FinancialTransaction {
  id            String          @id @default(cuid())
  type          TransactionType
  description   String
  amount        Float
  date          DateTime
  dueDate       DateTime?
  paidAt        DateTime?
  status        PaymentStatus   @default(PENDING)
  paymentMethod PaymentMethod?
  category      String?
  clientId      String?
  supplierId    String?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  client   Client?   @relation(fields: [clientId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
}
